[debug] [2026-07-23T05:20:10.454Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/raidkorea-f34c9/rulesets {"name":"projects/raidkorea-f34c9/rulesets/8f9424fe-68c3-4bad-abd7-f2e40191e03b","source":{"files":[{"content":"rules_version = '2';\n\n// ─────────────────────────────────────────────────────────────────────\n// WANION Firestore 규칙 v1 (P1)\n// 원칙:\n//  - uid = Firebase Auth uid 직접 사용 (kgusystem의 authlinks 간접층 제거)\n//  - 권한 = memberships/{uid}_{scopeType}_{scopeId} 문서의 (스코프, 역할)\n//  - 포인트(wallets/pointLedger)는 클라이언트 쓰기 전면 금지 — Functions 전용\n//  - 카운터(raids.counts, guides.up/down/score)는 증분 검증 브랜치로만 허용\n// ─────────────────────────────────────────────────────────────────────\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function signedIn() {\n      return request.auth != null;\n    }\n    function me() {\n      return request.auth.uid;\n    }\n    function membership(scopeType, scopeId) {\n      return get(/databases/$(database)/documents/memberships/$(me() + '_' + scopeType + '_' + scopeId)).data;\n    }\n    function hasRole(scopeType, scopeId, roles) {\n      return signedIn()\n        && exists(/databases/$(database)/documents/memberships/$(me() + '_' + scopeType + '_' + scopeId))\n        && membership(scopeType, scopeId).role in roles;\n    }\n    function isPlatformAdmin() {\n      return hasRole('platform', 'platform', ['owner', 'staff']);\n    }\n    // 소유자(대표) 단독 권한 — 멤버십 임명·해임, meta 변경 등 최상위 작업 전용.\n    // staff는 운영 보조(관리 화면·삭제 처리 등)만 가능하며 권한 구조 자체는 못 건드린다.\n    function isOwner() {\n      return hasRole('platform', 'platform', ['owner']);\n    }\n    // 레이드 host 스코프 관리 권한 (kgusystem useCanEdit 계승)\n    function canManageRaid(d) {\n      return isPlatformAdmin()\n        || (d.hostType == 'user' && signedIn() && d.hostId == me())\n        || (d.hostType == 'guild' && hasRole('guild', d.hostId, ['master', 'officer']))\n        || (d.hostType == 'team' && hasRole('team', d.hostId, ['leader', 'officer']))\n        || (d.hostType == 'alliance' && hasRole('alliance', d.hostId, ['officer']));\n    }\n    // 게시판 스코프 관리자 — global=플랫폼 운영진, guild/team=해당 조직 관리진\n    function isScopeAdmin(scopeType, scopeId) {\n      return isPlatformAdmin()\n        || (scopeType == 'guild' && hasRole('guild', scopeId, ['master', 'officer']))\n        || (scopeType == 'team' && hasRole('team', scopeId, ['leader', 'officer']));\n    }\n    // 게시판 스코프 열람·작성 자격 — global=로그인 유저, guild/team=소속원 전용 (사양 8.4)\n    function isScopeMember(scopeType, scopeId) {\n      return (scopeType == 'global' && signedIn())\n        || (scopeType == 'guild'\n            && (isPlatformAdmin() || hasRole('guild', scopeId, ['master', 'officer', 'member'])))\n        || (scopeType == 'team'\n            && (isPlatformAdmin() || hasRole('team', scopeId, ['leader', 'officer', 'member'])));\n    }\n    // counts.{tank|heal|dps}만 ±1 범위로 변경하는 업데이트인지 (신청 트랜잭션용)\n    function isCountsOnlyUpdate() {\n      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['counts'])\n        && request.resource.data.counts.tank >= 0\n        && request.resource.data.counts.heal >= 0\n        && request.resource.data.counts.dps >= 0\n        && (request.resource.data.counts.tank - resource.data.counts.tank) <= 1\n        && (request.resource.data.counts.tank - resource.data.counts.tank) >= -1\n        && (request.resource.data.counts.heal - resource.data.counts.heal) <= 1\n        && (request.resource.data.counts.heal - resource.data.counts.heal) >= -1\n        && (request.resource.data.counts.dps - resource.data.counts.dps) <= 1\n        && (request.resource.data.counts.dps - resource.data.counts.dps) >= -1;\n    }\n\n    // ── Users & characters ──────────────────────────────────────────\n    match /users/{uid} {\n      allow read: if true; // 공개 프로필 (작성자 표기·과시 경제)\n      allow create, update: if signedIn() && me() == uid;\n      allow delete: if isPlatformAdmin();\n\n      match /identities/{provider} {\n        allow read, write: if signedIn() && me() == uid;\n      }\n      match /characters/{charId} {\n        allow read: if true;\n        allow write: if signedIn() && me() == uid; // P3: BNet 워커(Admin SDK)가 주 담당\n      }\n    }\n\n    // ── Memberships — 변경은 운영자/Functions 경유 ──────────────────\n    match /memberships/{id} {\n      allow read: if true;\n      // 부트스트랩: 플랫폼 최초 1회, meta/super가 없을 때만 본인을 owner로 등록 가능.\n      // 이후의 모든 멤버십 임명·해임은 소유자(owner) 단독 권한 — staff 불가.\n      allow create: if isOwner()\n        || (\n          signedIn()\n          && id == me() + '_platform_platform'\n          && request.resource.data.role == 'owner'\n          && !exists(/databases/$(database)/documents/meta/super)\n        );\n      allow update, delete: if isOwner();\n    }\n\n    // ── 조직 엔티티 — 공개 프로필 전략 (비로그인 열람) ──────────────\n    match /guilds/{guildId} {\n      allow read: if true;\n      allow write: if isPlatformAdmin() || hasRole('guild', guildId, ['master']);\n    }\n    match /alliances/{allianceId} {\n      allow read: if true;\n      allow write: if isPlatformAdmin() || hasRole('alliance', allianceId, ['officer']);\n    }\n    match /teams/{teamId} {\n      allow read: if true;\n      allow write: if isPlatformAdmin() || hasRole('team', teamId, ['leader', 'officer']);\n    }\n\n    // ── Game data · zones · meta · config ───────────────────────────\n    match /gamedata/{docId} {\n      allow read: if true;\n      allow write: if isPlatformAdmin();\n    }\n    match /zones/{zoneId} {\n      allow read: if true;\n      allow write: if isPlatformAdmin();\n      match /bosses/{bossId} {\n        allow read: if true;\n        allow write: if isPlatformAdmin();\n      }\n    }\n    match /meta/{docId} {\n      allow read: if true;\n      allow create: if isOwner()\n        || (docId == 'super' && signedIn()\n            && !exists(/databases/$(database)/documents/meta/super));\n      allow update, delete: if isOwner();\n    }\n    match /config/{docId} {\n      allow read: if true;\n      allow write: if isPlatformAdmin();\n    }\n\n    // ── Raids ────────────────────────────────────────────────────────\n    match /raids/{raidId} {\n      allow read: if true; // 탐색 보드 공개 (SEO·홍보)\n      allow create: if canManageRaid(request.resource.data);\n      allow update: if (canManageRaid(resource.data) && canManageRaid(request.resource.data))\n        || (signedIn() && isCountsOnlyUpdate()); // 신청 트랜잭션의 counts 증감\n      allow delete: if canManageRaid(resource.data);\n\n      match /apps/{appId} {\n        allow read: if signedIn();\n        allow create: if canManageRaid(get(/databases/$(database)/documents/raids/$(raidId)).data)\n          || (\n            signedIn()\n            && appId == me()\n            && request.resource.data.userId == me()\n            && request.resource.data.isReservation == false\n          );\n        // 본인 수정 가능. wait/bench → active 자기 승격 금지 (승격은 관리자 전용)\n        allow update: if canManageRaid(get(/databases/$(database)/documents/raids/$(raidId)).data)\n          || (\n            signedIn()\n            && appId == me()\n            && request.resource.data.userId == me()\n            && request.resource.data.isReservation == false\n            && !(resource.data.status == 'wait' && request.resource.data.status == 'active')\n            && !(resource.data.status == 'bench' && request.resource.data.status == 'active')\n            && !(resource.data.status == 'pending' && request.resource.data.status == 'active')\n            && !(resource.data.status == 'pending' && request.resource.data.status == 'wait')\n          );\n        allow delete: if canManageRaid(get(/databases/$(database)/documents/raids/$(raidId)).data)\n          || (signedIn() && appId == me());\n      }\n\n      match /memos/{appId} {\n        allow read, write: if canManageRaid(get(/databases/$(database)/documents/raids/$(raidId)).data)\n          || (signedIn() && appId == me());\n      }\n\n      // 시뮬레이션 — 본문서와 분리 저장 (kgusystem 쓰기증폭 문제의 구조적 해결)\n      match /sim/{docId} {\n        allow read: if signedIn();\n        allow write: if canManageRaid(get(/databases/$(database)/documents/raids/$(raidId)).data);\n      }\n\n      match /logs/{logId} {\n        allow read: if isPlatformAdmin();\n        allow write: if false; // Functions 전용\n      }\n\n      // 손님파티 — 관리(등록·수정·삭제)는 생성자+슈퍼만 (사양 7.1)\n      // guests: 캐릭명·서버·클래스·유형 (열람: 그 공대 신청자 + 관리자)\n      // guestFees: 업비 골드 — 문서 분리로 비공개 구현 (feePublic 시 공대원만)\n      match /guests/{guestId} {\n        allow read: if signedIn() && (\n          get(/databases/$(database)/documents/raids/$(raidId)).data.createdBy == me()\n          || isPlatformAdmin()\n          || exists(/databases/$(database)/documents/raids/$(raidId)/apps/$(me()))\n        );\n        // '손님 지원': BNet 연동 회원이 본인을 applied 상태로만 등록 가능 (승인은 생성자·슈퍼)\n        allow create: if (signedIn()\n            && get(/databases/$(database)/documents/raids/$(raidId)).data.createdBy == me())\n          || isPlatformAdmin()\n          || (signedIn()\n              && request.resource.data.linkedUid == me()\n              && request.resource.data.status == 'applied');\n        allow update, delete: if (signedIn()\n            && get(/databases/$(database)/documents/raids/$(raidId)).data.createdBy == me())\n          || isPlatformAdmin();\n      }\n      match /guestFees/{guestId} {\n        allow read: if signedIn() && (\n          get(/databases/$(database)/documents/raids/$(raidId)).data.createdBy == me()\n          || isPlatformAdmin()\n          || (\n            get(/databases/$(database)/documents/raids/$(raidId)).data.feePublic == true\n            && exists(/databases/$(database)/documents/raids/$(raidId)/apps/$(me()))\n          )\n        );\n        allow write: if (signedIn()\n            && get(/databases/$(database)/documents/raids/$(raidId)).data.createdBy == me())\n          || isPlatformAdmin();\n      }\n\n      match /cancels/{cancelId} {\n        allow read: if canManageRaid(get(/databases/$(database)/documents/raids/$(raidId)).data)\n          || (signedIn() && resource.data.userId == me());\n        allow create: if signedIn()\n          && (request.resource.data.userId == me()\n              || canManageRaid(get(/databases/$(database)/documents/raids/$(raidId)).data));\n        allow update: if false;\n        allow delete: if canManageRaid(get(/databases/$(database)/documents/raids/$(raidId)).data);\n      }\n    }\n\n    // ── Guides (공략게시판) ──────────────────────────────────────────\n    match /guides/{guideId} {\n      // global 스코프 = 비로그인 공개(SEO). 길드·공대 스코프 글은 로그인 필요\n      // (P2: 커스텀 클레임으로 멤버십 단위 정밀 차단 예정 — 현재는 UI 필터 병행)\n      allow read: if resource.data.scopeKeys.hasAny(['global']) || signedIn();\n\n      allow create: if signedIn()\n        && request.resource.data.authorId == me()\n        && request.resource.data.up == 0\n        && request.resource.data.down == 0\n        && request.resource.data.score == 0;\n\n      allow update: if\n        // (a) 작성자 본문 수정 — 카운터·작성자·보상 필드 불가침\n        (\n          signedIn()\n          && resource.data.authorId == me()\n          && request.resource.data.diff(resource.data).affectedKeys()\n               .hasOnly(['title', 'body', 'links', 'difficulty', 'updatedAt'])\n        )\n        // (b) 투표 트랜잭션의 카운터 증감 (±1, score 정합 강제)\n        || (\n          signedIn()\n          && resource.data.authorId != me()\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['up', 'down', 'score'])\n          && (request.resource.data.up - resource.data.up) >= -1\n          && (request.resource.data.up - resource.data.up) <= 1\n          && (request.resource.data.down - resource.data.down) >= -1\n          && (request.resource.data.down - resource.data.down) <= 1\n          && request.resource.data.score == request.resource.data.up - request.resource.data.down\n        )\n        || isPlatformAdmin();\n\n      allow delete: if isPlatformAdmin() || (signedIn() && resource.data.authorId == me());\n\n      // 투표 — 익명 보장: 본인 표만 조회 가능\n      match /votes/{uid} {\n        allow read: if signedIn() && me() == uid;\n        allow create, update: if signedIn() && me() == uid\n          && request.resource.data.value in [1, -1]\n          && get(/databases/$(database)/documents/guides/$(guideId)).data.authorId != me();\n        allow delete: if signedIn() && me() == uid;\n      }\n    }\n\n    // ── Boards (통합 게시판 메타 — 관리형 카테고리 목록, 사양 8.5) ───\n    // boardId: 'global' | 'guild_{id}' | 'team_{id}'\n    match /boards/{boardId} {\n      allow read: if true; // 카테고리 목록은 공개 (글 열람 권한은 posts에서 통제)\n      allow create: if isScopeAdmin(request.resource.data.scopeType, request.resource.data.scopeId);\n      allow update: if isScopeAdmin(resource.data.scopeType, resource.data.scopeId)\n        && request.resource.data.scopeType == resource.data.scopeType\n        && request.resource.data.scopeId == resource.data.scopeId;\n      allow delete: if isPlatformAdmin();\n    }\n\n    // ── Posts (통합 게시판 — 스코프 3층: global | guild | team) ──────\n    // 카테고리는 고정 enum 검증 대신 문자열 + 공지 권한류만 검증 (사양 8.5).\n    // 관리자 전용 카테고리 목록은 boards/{boardId}.adminOnlyCategories가 진실의 원천.\n    match /posts/{postId} {\n      allow read: if isScopeMember(resource.data.scopeType, resource.data.scopeId);\n\n      allow create: if signedIn()\n        && request.resource.data.authorId == me()\n        && request.resource.data.commentCount == 0\n        && request.resource.data.scopeType in ['global', 'guild', 'team']\n        && isScopeMember(request.resource.data.scopeType, request.resource.data.scopeId)\n        // boardId 정직성 — adminOnly 판정에 쓰이므로 위조 불가여야 함\n        && (\n          (request.resource.data.scopeType == 'global' && request.resource.data.boardId == 'global')\n          || (request.resource.data.scopeType != 'global'\n              && request.resource.data.boardId\n                 == request.resource.data.scopeType + '_' + request.resource.data.scopeId)\n        )\n        && (\n          isScopeAdmin(request.resource.data.scopeType, request.resource.data.scopeId)\n          || (\n            // 일반 유저: 고정 불가 + 관리자 전용 카테고리 작성 불가\n            request.resource.data.pinned == false\n            && (\n              (!exists(/databases/$(database)/documents/boards/$(request.resource.data.boardId))\n                && request.resource.data.category != 'notice')\n              || (exists(/databases/$(database)/documents/boards/$(request.resource.data.boardId))\n                && !(request.resource.data.category\n                     in get(/databases/$(database)/documents/boards/$(request.resource.data.boardId)).data.adminOnlyCategories))\n            )\n          )\n        );\n\n      allow update: if signedIn() && (\n        // (a) 댓글 트랜잭션의 commentCount ±1\n        (\n          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])\n          && (request.resource.data.commentCount == resource.data.commentCount + 1\n              || request.resource.data.commentCount == resource.data.commentCount - 1)\n        )\n        // (b) 작성자 본문 수정 — 스코프·카테고리·고정·카운터 불가침\n        || (\n          resource.data.authorId == me()\n          && request.resource.data.diff(resource.data).affectedKeys()\n               .hasOnly(['title', 'body', 'updatedAt'])\n        )\n        // (c) 스코프 관리자 — 고정/해제 등. 스코프·작성자 이전은 불가\n        || (\n          isScopeAdmin(resource.data.scopeType, resource.data.scopeId)\n          && request.resource.data.scopeType == resource.data.scopeType\n          && request.resource.data.scopeId == resource.data.scopeId\n          && request.resource.data.authorId == resource.data.authorId\n        )\n      );\n\n      allow delete: if isScopeAdmin(resource.data.scopeType, resource.data.scopeId)\n        || (signedIn() && resource.data.authorId == me());\n\n      match /comments/{commentId} {\n        allow read: if isScopeMember(\n          get(/databases/$(database)/documents/posts/$(postId)).data.scopeType,\n          get(/databases/$(database)/documents/posts/$(postId)).data.scopeId\n        );\n        allow create: if signedIn()\n          && request.resource.data.authorId == me()\n          && isScopeMember(\n            get(/databases/$(database)/documents/posts/$(postId)).data.scopeType,\n            get(/databases/$(database)/documents/posts/$(postId)).data.scopeId\n          );\n        allow update: if signedIn() && (\n          isPlatformAdmin()\n          || (resource.data.authorId == me()\n              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['body', 'updatedAt']))\n        );\n        allow delete: if signedIn() && (\n          resource.data.authorId == me()\n          || isScopeAdmin(\n            get(/databases/$(database)/documents/posts/$(postId)).data.scopeType,\n            get(/databases/$(database)/documents/posts/$(postId)).data.scopeId\n          )\n        );\n      }\n    }\n\n    // ── 포인트 — 클라이언트 쓰기 전면 금지 ──────────────────────────\n    match /wallets/{uid} {\n      allow read: if true; // 누적 P·계급 공개 = 과시 경제\n      allow write: if false; // Functions 전용\n    }\n    match /pointLedger/{txId} {\n      allow read: if signedIn() && resource.data.uid == me();\n      allow write: if false; // Functions 전용\n    }\n    match /dailyCheckins/{id} {\n      allow read: if signedIn() && resource.data.uid == me();\n      allow create: if signedIn()\n        && request.resource.data.uid == me()\n        && id == me() + '_' + request.resource.data.dateKey; // 하루 1회 중복 방지 키\n      allow update, delete: if false;\n    }\n    match /weeklyAttendance/{id} {\n      allow read: if signedIn();\n      allow write: if false; // Functions 전용\n    }\n\n    // ── 신고 (노쇼 등) — 생성만, 심사는 운영자 ──────────────────────\n    match /reports/{reportId} {\n      allow read: if isPlatformAdmin() || (signedIn() && resource.data.reporterId == me());\n      allow create: if signedIn() && request.resource.data.reporterId == me()\n        && request.resource.data.status == 'pending';\n      allow update, delete: if isPlatformAdmin();\n    }\n\n    // ── 애드온 브릿지 세션 (P4에서 정의) ────────────────────────────\n    match /addonSessions/{code} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-07-23T05:20:09.774991Z","metadata":{"services":["cloud.firestore"]}}
